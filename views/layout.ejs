<!DOCTYPE html>
<html lang="es-MX">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <!-- SEO Meta Tags -->
    <title><%= title %> | PintuMex - Puebla</title>
    <meta name="description" content="<%= description || 'Pinturas Mexicanas de Puebla - Venta de pinturas, impermeabilizantes y recubrimientos de alta calidad. Sucursales en Puebla. Envíos a toda la república.' %>">
    <meta name="keywords" content="pinturas puebla, pinturas mexicanas, impermeabilizantes, vinílicas, esmaltes, pintumex, pinturas profesionales, pinturas baratas puebla">
    <meta name="author" content="PintuMex de Puebla.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://pintumex.com.mx<%= typeof currentUrl !== 'undefined' ? currentUrl : '' %>">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://pintumex.com.mx">
    <meta property="og:title" content="<%= title %> | Pintumex">
    <meta property="og:description" content="<%= description || 'Pinturas de calidad profesional en Puebla' %>">
    <meta property="og:image" content="https://pintumex.com.mx/images/logo.webp">
    <meta property="og:locale" content="es_MX">
    <meta property="og:site_name" content="Pintumex">
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://pintumex.com.mx">
    <meta property="twitter:title" content="<%= title %> | Pintumex">
    <meta property="twitter:description" content="<%= description || 'Pinturas de calidad profesional en Puebla' %>">
    <meta property="twitter:image" content="https://pintumex.com.mx/images/logo.webp">
    
    <!-- Geo Tags para SEO Local -->
    <meta name="geo.region" content="MX-PUE">
    <meta name="geo.placename" content="Puebla">
    <meta name="geo.position" content="19.0414;-98.2063">
    <meta name="ICBM" content="19.0414, -98.2063">
    
    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/images/logo.webp">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
        <!-- Custom CSS -->
        <link rel="stylesheet" href="/css/main.css">

        <% 
                const primaryStore = (typeof stores !== 'undefined' && stores[0]) ? stores[0] : null;
                const secondaryStore = (typeof stores !== 'undefined' && stores[1]) ? stores[1] : null;
                const splitHours = (value, fallback) => {
                    if (!value || String(value).toLowerCase() === 'cerrado') {
                        return fallback;
                    }
                    const parts = value.split(' - ');
                    return parts.length === 2 ? parts : fallback;
                };
                const weekdayHours = splitHours(primaryStore && primaryStore.hours ? primaryStore.hours.monday : null, ['08:00', '18:00']);
                const saturdayHours = splitHours(primaryStore && primaryStore.hours ? primaryStore.hours.saturday : null, ['09:00', '15:00']);
                const primaryWhatsapp = primaryStore ? (primaryStore.whatsapp || primaryStore.phone) : '+522222941010';
                const secondaryWhatsapp = secondaryStore ? (secondaryStore.whatsapp || secondaryStore.phone) : '';
        %>
    
        <!-- Schema.org Markup para Negocio Local -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "HardwareStore",
      "name": "Pinturas Mexicanas de Puebla S.A. de C.V.",
      "image": "https://pintumex.com.mx/images/logo.webp",
      "@id": "https://pintumex.com.mx",
      "url": "https://pintumex.com.mx",
            "telephone": "<%= primaryStore ? primaryStore.phone : '+522222941010' %>",
      "address": {
        "@type": "PostalAddress",
                "streetAddress": "<%= primaryStore ? primaryStore.address : 'Puebla, Mexico' %>",
                "addressLocality": "Puebla",
                "postalCode": "72000",
        "addressCountry": "MX"
      },
      "geo": {
        "@type": "GeoCoordinates",
                "latitude": <%= primaryStore ? primaryStore.latitude : 19.0414 %>,
                "longitude": <%= primaryStore ? primaryStore.longitude : -98.2063 %>
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                    "opens": "<%= weekdayHours[0] %>",
                    "closes": "<%= weekdayHours[1] %>"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
                    "opens": "<%= saturdayHours[0] %>",
                    "closes": "<%= saturdayHours[1] %>"
        }
      ],
      "sameAs": [
        "https://www.facebook.com/pintumex",
        "https://www.instagram.com/pintumex"
      ],
      "priceRange": "$$"
    }
    </script>
    
    <style>
        :root {
            --primary-color: #1e40af;
            --primary-dark: #1e3a8a;
            --secondary-color: #1976d2;
            --accent-color: #ffa000;
            --text-color: #212121;
            --light-bg: #f5f5f5;
            --border-color: #e0e0e0;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="/images/logo.webp" alt="Pintumex Logo" height="36" class="me-2">
                <span class="brand-text">PINTUMEX</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="/productos">Productos</a></li>
                     <li class="nav-item"><a class="nav-link" href="/servicios">Servicios</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tiendas">Tiendas</a></li>
                    <li class="nav-item"><a class="nav-link" href="/acerca-de">Acerca de</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/carrito">
                            <i class="fas fa-shopping-cart"></i> Carrito
                            <% if(cartCount > 0) { %>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    <%= cartCount %>
                                </span>
                            <% } %>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <% if(typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Main Content -->
    <main>
        <%- body %>
    </main>

    <!-- Botón flotante de WhatsApp -->
    <div class="whatsapp-float">
        <a href="https://wa.me/<%= primaryWhatsapp.replace(/[^0-9]/g, '') %>?text=Hola,%20me%20interesa%20obtener%20más%20información%20sobre%20sus%20productos" target="_blank" class="whatsapp-btn">
            <i class="fab fa-whatsapp me-2"></i> Contáctanos
        </a>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white mt-5 py-5">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-3 mb-4">
                    <h5><img src="/images/logo.webp" alt="Pintumex" height="30" class="mb-2"></h5>
                    <p class="text-white-50">Pinturas Mexicanas de Puebla S.A. de C.V. Tu proveedor de confianza en pinturas y recubrimientos de la más alta calidad.</p>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Enlaces Rápidos</h5>
                    <ul class="list-unstyled">
                        <li><a href="/productos" class="text-white-50 text-decoration-none hover-link">Productos</a></li>
                        <li><a href="/tiendas" class="text-white-50 text-decoration-none hover-link">Tiendas</a></li>
                        <li><a href="/acerca-de" class="text-white-50 text-decoration-none hover-link">Acerca de</a></li>
                        <li><a href="/contacto" class="text-white-50 text-decoration-none hover-link">Contacto</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Contacto</h5>
                    <p class="text-white-50">
                        <% if (primaryStore) { %>
                            <i class="fas fa-phone"></i> <%= primaryStore.phone %><br>
                        <% } %>
                        <% if (secondaryStore) { %>
                            <i class="fas fa-phone"></i> <%= secondaryStore.phone %><br>
                        <% } %>
                        <% if (primaryStore) { %>
                            <i class="fas fa-envelope"></i> <%= primaryStore.email %><br>
                            <i class="fas fa-map-marker-alt"></i> <%= primaryStore.address %>
                        <% } %>
                    </p>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Contáctanos por WhatsApp</h5>
                    <div class="mb-2">
                        <% if (primaryStore) { %>
                            <a href="https://wa.me/<%= primaryWhatsapp.replace(/[^0-9]/g, '') %>" target="_blank" class="btn btn-success btn-sm w-100 mb-2">
                                <i class="fab fa-whatsapp"></i> <%= primaryStore.name %>
                            </a>
                        <% } %>
                        <% if (secondaryStore) { %>
                            <a href="https://wa.me/<%= secondaryWhatsapp.replace(/[^0-9]/g, '') %>" target="_blank" class="btn btn-success btn-sm w-100">
                                <i class="fab fa-whatsapp"></i> <%= secondaryStore.name %>
                            </a>
                        <% } %>
                    </div>
                    <div class="mt-3">
                        <h6>Síguenos</h6>
                        <a href="#" class="text-white-50 me-3"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="text-white-50 me-3"><i class="fab fa-instagram fa-lg"></i></a>
                    </div>
                </div>
            </div>
            <hr class="bg-white-50">
            <div class="footer-bottom">
                <p class="footer-legal">
                    <span class="footer-legal-line">&copy; 2026 Pintumex Puebla | Diseñado por: Axel Gutiérrez</span>
                    <span class="footer-legal-line">
                        <a href="/terminos">Términos y Condiciones</a> | 
                        <a href="/privacidad">Política de Privacidad</a>
                    </span>
                </p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Custom JS -->
    <script src="/js/main.js"></script>
    
    <% if(typeof googleMapsApiKey !== 'undefined' && googleMapsApiKey !== 'YOUR_API_KEY') { %>
        <script async defer src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>"></script>
    <% } %>
</body>
</html>
