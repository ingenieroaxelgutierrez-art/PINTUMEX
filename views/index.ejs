            font-size: 0.9rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero-section {
                min-height: 400px;
                padding: 60px 0;
            }

            .hero-section h1 {
                font-size: 2rem;
            }

            .hero-section .lead {
