<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="d-flex flex-column justify-content-center align-items-center min-vh-100 bg-light">
        <div class="text-center">
            <i class="fas fa-exclamation-triangle fa-5x text-warning mb-4"></i>
            <h1 class="display-5 fw-bold mb-3">Oops! Algo salió mal</h1>
            <p class="lead text-muted mb-4"><%= message %></p>
            <div class="d-flex gap-2 justify-content-center">
                <a href="/" class="btn btn-danger btn-lg fw-bold">
                    <i class="fas fa-home"></i> Ir a Inicio
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-danger btn-lg fw-bold">
                    <i class="fas fa-arrow-left"></i> Volver
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
