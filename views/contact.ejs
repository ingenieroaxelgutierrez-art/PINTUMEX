<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contacto - Pintumex</title>
    <link rel="icon" type="image/webp" href="/images/logo.webp">
    <link rel="apple-touch-icon" href="/images/logo.webp">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        :root {
            --primary-blue: #1e40af;  /* Azul Pintumex */
            --dark-blue: #1e3a8a;     /* Azul oscuro */
            --primary-green: #16a34a; /* Verde Pintumex */
            --accent-gold: #ffa000;
            --light-bg: #f5f5f5;
            --dark-text: #212121;
        }

        .contact-hero {
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--dark-blue) 100%);
            color: white;
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }

        .contact-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120"><path d="M0,50 Q300,100 600,50 T1200,50 L1200,120 L0,120 Z" fill="rgba(255,255,255,0.1)"/></svg>');
            background-repeat: repeat-x;
            opacity: 0.5;
        }

        .contact-hero h1 {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            position: relative;
            z-index: 1;
        }

        .contact-hero p {
            font-size: 1.3rem;
            font-weight: 300;
            position: relative;
            z-index: 1;
        }

        .contact-card {
            background: white;
            border: none;
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            height: 100%;
        }

        .contact-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(30, 64, 175, 0.2);
        }

        .contact-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 25px;
            background: linear-gradient(135deg, var(--primary-blue), var(--dark-blue));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            transition: all 0.3s ease;
        }

        .contact-card:hover .contact-icon {
            transform: scale(1.15) rotate(5deg);
        }

        .contact-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--dark-text);
            margin-bottom: 15px;
        }

        .contact-text {
            color: #666;
            font-size: 1rem;
            margin-bottom: 20px;
        }

        .contact-button {
            background: var(--primary-blue);
            color: white;
            border: 2px solid var(--primary-blue);
            padding: 12px 24px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 700;
            transition: all 0.3s ease;
            display: inline-block;
        }

        .contact-button:hover {
            background: white;
            color: var(--primary-blue);
        }

        .contact-form {
            background: white;
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        }

        .form-header {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--dark-text);
            margin-bottom: 10px;
            padding-bottom: 20px;
            border-bottom: 3px solid var(--primary-blue);
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 700;
            color: var(--dark-text);
            margin-bottom: 10px;
            font-size: 1rem;
        }

        .form-control {
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 15px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 0.2rem rgba(30, 64, 175, 0.25);
        }

        .form-textarea {
            min-height: 150px;
            resize: vertical;
            font-family: 'Poppins', sans-serif;
        }

        .submit-button {
            background: linear-gradient(135deg, var(--primary-blue), var(--dark-blue));
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
        }

        .submit-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(30, 64, 175, 0.3);
        }

        .faq-section {
            padding: 60px 0;
        }

        .faq-title {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--dark-text);
            margin-bottom: 50px;
            text-align: center;
        }

        .accordion-button:not(.collapsed) {
            background: var(--light-bg);
            color: var(--primary-blue);
            font-weight: 700;
        }

        .accordion-button {
            background: white;
            border: 2px solid #e0e0e0;
            border-radius: 8px !important;
            margin-bottom: 15px;
            font-weight: 600;
            color: var(--dark-text);
            padding: 15px 25px;
            transition: all 0.3s ease;
        }

        .accordion-button:hover {
            background: var(--light-bg);
            border-color: var(--primary-blue);
        }

        .accordion-button::after {
            background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path fill="none" stroke="%23d32f2f" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 5l6 6 6-6"/></svg>');
            background-color: transparent;
        }

        .accordion-body {
            background: white;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 20px;
            color: #666;
            line-height: 1.6;
        }

        .accordion-item {
            border: none;
            margin-bottom: 0;
        }

        @media (max-width: 767px) {
            .contact-hero h1 {
                font-size: 2rem;
            }

            .contact-hero p {
                font-size: 1rem;
            }

            .contact-hero {
                padding: 50px 0;
            }

            .contact-card {
                padding: 30px;
            }

            .contact-form {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>
    <% 
        const primaryStore = (typeof stores !== 'undefined' && stores[0]) ? stores[0] : null;
        const secondaryStore = (typeof stores !== 'undefined' && stores[1]) ? stores[1] : null;
        const primaryWhatsapp = primaryStore ? (primaryStore.whatsapp || primaryStore.phone) : '522222941010';
        const secondaryWhatsapp = secondaryStore ? (secondaryStore.whatsapp || secondaryStore.phone) : '';
    %>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="/images/logo.webp" alt="Pintumex" height="36" class="me-2">
                <span class="brand-text">PINTUMEX</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="/productos">Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/servicios">Servicios</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tiendas">Tiendas</a></li>
                    <li class="nav-item"><a class="nav-link" href="/acerca-de">Acerca de</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/contacto">Contacto</a></li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/carrito">
                            <i class="fas fa-shopping-cart"></i> Carrito
                            <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">0</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="contact-hero">
        <div class="container position-relative" style="z-index: 2;">
            <h1><i class="fas fa-headset me-3"></i>Contacto</h1>
            <p class="mb-0">Estamos aquí para ayudarte en todo lo que necesites</p>
        </div>
    </section>

    <!-- Contact Information -->
    <section class="py-5" style="background: var(--light-bg);">
        <div class="container">
            <div class="row g-4 mb-5">
                <!-- Phone -->
                <div class="col-md-4">
                    <div class="contact-card">
                        <div class="contact-icon">
                            <i class="fas fa-phone"></i>
                        </div>
                        <h3 class="contact-title">Teléfono</h3>
                        <p class="contact-text">
                            <% if (primaryStore) { %>
                                <%= primaryStore.name %>: <%= primaryStore.phone %><br>
                            <% } %>
                            <% if (secondaryStore) { %>
                                <%= secondaryStore.name %>: <%= secondaryStore.phone %>
                            <% } %>
                        </p>
                        <a href="tel:<%= primaryStore ? primaryStore.phone : '' %>" class="contact-button">
                            <i class="fas fa-phone me-2"></i>Llamar Ahora
                        </a>
                    </div>
                </div>

                <!-- WhatsApp -->
                <div class="col-md-4">
                    <div class="contact-card">
                        <div class="contact-icon" style="background: #25D366;">
                            <i class="fab fa-whatsapp"></i>
                        </div>
                        <h3 class="contact-title">WhatsApp</h3>
                        <p class="contact-text">
                            Disponible las 24 horas<br>
                            Respuesta rápida garantizada
                        </p>
                        <a href="https://wa.me/<%= primaryWhatsapp.replace(/[^0-9]/g, '') %>?text=Hola%20Pintumex,%20tengo%20una%20consulta" 
                           target="_blank" class="contact-button" style="background: #25D366; border-color: #25D366;">
                            <i class="fab fa-whatsapp me-2"></i>Enviar Mensaje
                        </a>
                    </div>
                </div>

                <!-- Email -->
                <div class="col-md-4">
                    <div class="contact-card">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <h3 class="contact-title">Email</h3>
                        <p class="contact-text">
                            <% if (primaryStore) { %>
                                <%= primaryStore.email %><br>
                            <% } %>
                            <% if (secondaryStore && secondaryStore.email !== (primaryStore ? primaryStore.email : '')) { %>
                                <%= secondaryStore.email %>
                            <% } %>
                        </p>
                        <a href="mailto:<%= primaryStore ? primaryStore.email : '' %>" class="contact-button">
                            <i class="fas fa-envelope me-2"></i>Enviar Email
                        </a>
                    </div>
                </div>
            </div>

            <!-- Locations -->
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="contact-card">
                        <h3 class="contact-title mb-4">
                            <i class="fas fa-map-marker-alt" style="color: var(--primary-blue);"></i> <%= primaryStore ? primaryStore.name : 'Sucursal 1' %>
                        </h3>
                        <p class="contact-text"><%= primaryStore ? primaryStore.address : '' %></p>
                        <p style="color: #4caf50; margin-bottom: 20px;">
                            <i class="fas fa-check-circle me-2"></i><strong>Abierto</strong>
                        </p>
                        <div style="font-size: 0.95rem; color: #666; margin-bottom: 20px;">
                            <div><strong>Lunes:</strong> <%= primaryStore && primaryStore.hours ? primaryStore.hours.monday : '' %></div>
                            <div><strong>Martes:</strong> <%= primaryStore && primaryStore.hours ? primaryStore.hours.tuesday : '' %></div>
                            <div><strong>Miércoles:</strong> <%= primaryStore && primaryStore.hours ? primaryStore.hours.wednesday : '' %></div>
                            <div><strong>Jueves:</strong> <%= primaryStore && primaryStore.hours ? primaryStore.hours.thursday : '' %></div>
                            <div><strong>Viernes:</strong> <%= primaryStore && primaryStore.hours ? primaryStore.hours.friday : '' %></div>
                            <div><strong>Sábado:</strong> <%= primaryStore && primaryStore.hours ? primaryStore.hours.saturday : '' %></div>
                            <div><strong>Domingo:</strong> <%= primaryStore && primaryStore.hours ? primaryStore.hours.sunday : '' %></div>
                        </div>
                        <a href="<%= primaryStore ? primaryStore.googleMapsUrl : 'https://maps.google.com/' %>" 
                           target="_blank" class="contact-button" style="width: 100%;">
                            <i class="fas fa-directions me-2"></i>Ver en Google Maps
                        </a>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="contact-card">
                        <h3 class="contact-title mb-4">
                            <i class="fas fa-map-marker-alt" style="color: var(--primary-blue);"></i> <%= secondaryStore ? secondaryStore.name : 'Sucursal 2' %>
                        </h3>
                        <p class="contact-text"><%= secondaryStore ? secondaryStore.address : '' %></p>
                        <p style="color: #4caf50; margin-bottom: 20px;">
                            <i class="fas fa-check-circle me-2"></i><strong>Abierto</strong>
                        </p>
                        <div style="font-size: 0.95rem; color: #666; margin-bottom: 20px;">
                            <div><strong>Lunes:</strong> <%= secondaryStore && secondaryStore.hours ? secondaryStore.hours.monday : '' %></div>
                            <div><strong>Martes:</strong> <%= secondaryStore && secondaryStore.hours ? secondaryStore.hours.tuesday : '' %></div>
                            <div><strong>Miércoles:</strong> <%= secondaryStore && secondaryStore.hours ? secondaryStore.hours.wednesday : '' %></div>
                            <div><strong>Jueves:</strong> <%= secondaryStore && secondaryStore.hours ? secondaryStore.hours.thursday : '' %></div>
                            <div><strong>Viernes:</strong> <%= secondaryStore && secondaryStore.hours ? secondaryStore.hours.friday : '' %></div>
                            <div><strong>Sábado:</strong> <%= secondaryStore && secondaryStore.hours ? secondaryStore.hours.saturday : '' %></div>
                            <div><strong>Domingo:</strong> <%= secondaryStore && secondaryStore.hours ? secondaryStore.hours.sunday : '' %></div>
                        </div>
                        <a href="<%= secondaryStore ? secondaryStore.googleMapsUrl : 'https://maps.google.com/' %>" target="_blank" class="contact-button" style="width: 100%;">
                            <i class="fas fa-directions me-2"></i>Ver en Google Maps
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Form -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-8 mx-auto">
                    <div class="contact-form">
                        <h2 class="form-header">
                            <i class="fas fa-envelope me-2" style="color: var(--primary-blue);"></i>Envíanos tu Mensaje
                        </h2>

                        <form method="POST" action="/contacto">
                            <div class="form-group">
                                <label class="form-label">Nombre Completo *</label>
                                <input type="text" class="form-control" name="name" placeholder="Tu nombre" required>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Email *</label>
                                <input type="email" class="form-control" name="email" placeholder="tu@email.com" required>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Teléfono *</label>
                                <input type="tel" class="form-control" name="phone" placeholder="+52 1234567890" required>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Asunto *</label>
                                <select class="form-control" name="subject" required>
                                    <option value="">-- Seleccionar asunto --</option>
                                    <option value="consulta">Consulta General</option>
                                    <option value="productos">Información de Productos</option>
                                    <option value="compra">Consulta sobre Compra</option>
                                    <option value="pedido">Estado de Pedido</option>
                                    <option value="reclamo">Reclamo o Sugerencia</option>
                                    <option value="otro">Otro</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Mensaje *</label>
                                <textarea class="form-control form-textarea" name="message" placeholder="Cuéntanos cómo podemos ayudarte..." required></textarea>
                            </div>

                            <button type="submit" class="submit-button">
                                <i class="fas fa-paper-plane me-2"></i>Enviar Mensaje
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section" style="background: var(--light-bg);">
        <div class="container">
            <h2 class="faq-title">Preguntas Frecuentes</h2>
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="accordion" id="faqAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                    <i class="fas fa-clock me-2" style="color: var(--primary-blue);"></i>
                                    ¿Cuál es el horario de atención?
                                </button>
                            </h2>
                            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Lunes a Viernes: 8:00 AM a 6:00 PM | Sábados: 9:00 AM a 2:00 PM | Domingos: Cerrado
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                    <i class="fas fa-truck me-2" style="color: var(--primary-blue);"></i>
                                    ¿Realizan entregas a domicilio?
                                </button>
                            </h2>
                            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Sí, realizamos entregas a toda la zona metropolitana de Puebla. Consulta con nosotros por WhatsApp o teléfono para conocer costos y tiempos de entrega.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                    <i class="fas fa-credit-card me-2" style="color: var(--primary-blue);"></i>
                                    ¿Qué métodos de pago aceptan?
                                </button>
                            </h2>
                            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Aceptamos efectivo, tarjetas de crédito/débito, transferencias bancarias. Contacta con nosotros para conocer las opciones de pago en línea.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                    <i class="fas fa-check-circle me-2" style="color: var(--primary-blue);"></i>
                                    ¿Todos los productos tienen garantía?
                                </button>
                            </h2>
                            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Sí, todos nuestros productos son 100% originales y vienen con garantía del fabricante. En caso de defecto, te asesoraremos en todo el proceso.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                                    <i class="fas fa-question-circle me-2" style="color: var(--primary-blue);"></i>
                                    ¿Puedo hacer pedidos en línea?
                                </button>
                            </h2>
                            <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Puedes explorar nuestro catálogo en línea y hacer tu pedido directamente por WhatsApp. Nuestro equipo procesará tu orden y coordinará la entrega.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container py-5">
            <div class="row mb-4 justify-content-between">
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-paint-brush me-2"></i>Pintumex</h5>
                    <p>Pinturas Mexicanas de Puebla S.A. de C.V.<br>Tu proveedor de confianza en pinturas y recubrimientos de la más alta calidad desde 2010.</p>
                </div>
                <div class="col-md-3 col-lg-2 mb-4">
                    <h5>Navegación</h5>
                    <ul class="list-unstyled mb-0">
                        <li><a href="/">Inicio</a></li>
                        <li><a href="/productos">Productos</a></li>
                        <li><a href="/servicios">Servicios</a></li>
                        <li><a href="/tiendas">Tiendas</a></li>
                        <li><a href="/acerca-de">Acerca de</a></li>
                        <li><a href="/contacto">Contacto</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Contacto</h5>
                    <p>
                        <% if (primaryStore) { %>
                            <i class="fas fa-phone me-2"></i><%= primaryStore.phone %><br>
                        <% } %>
                        <% if (secondaryStore) { %>
                            <i class="fas fa-phone me-2"></i><%= secondaryStore.phone %><br>
                        <% } %>
                        <% if (primaryStore) { %>
                            <i class="fas fa-envelope me-2"></i><%= primaryStore.email %><br>
                            <i class="fas fa-map-marker-alt me-2"></i><%= primaryStore.address %>
                        <% } %>
                    </p>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.15); margin-bottom: 1.5rem;">
            <div class="footer-bottom">
                <p class="footer-legal">
                    <span class="footer-legal-line">&copy; 2026 Pintumex Puebla | Diseñado por: Axel Gutiérrez</span>
                    <span class="footer-legal-line"><span class="footer-legal-links"><a href="/terminos">Términos y Condiciones</a> <span style="opacity:0.5">|</span> <a href="/privacidad">Política de Privacidad</a></span></span>
                </p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>


