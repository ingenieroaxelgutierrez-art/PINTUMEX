
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/webp" href="/images/logo.webp">
    <link rel="apple-touch-icon" href="/images/logo.webp">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
<style>
  /* ============================= */
  :root {
  --primary-blue: #1e40af;
  --dark-blue: #1e3a8a;
  --primary-green: #16a34a;
  --accent-light: #38bdf8;
  --white: #ffffff;
}
/* SERVICES HERO */
/* ============================= */
.services-hero {
    position: relative;
    background: 
        linear-gradient(rgba(30, 64, 175, 0.75), rgba(30, 58, 138, 0.75)),
        url('/images/services.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: white;
    padding: 120px 20px;
}

.services-hero::after {
    content: '';
    position: absolute;
    bottom: -20px;
    left: 0;
    width: 100%;
    height: 60px;
    background: var(--white);
    border-top-left-radius: 50% 40px;
    border-top-right-radius: 50% 40px;
}

.services-hero h1 {
    font-size: 3rem;
    font-weight: 800;
}

.services-hero p {
    font-size: 1.2rem;
    opacity: 0.95;
}
   /* Navbar Estilo */
        .navbar {
            background: linear-gradient(90deg, #2d4a75, #1a2744) !important;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            padding: 1rem 0;
        }

        .navbar-brand {
            font-family: 'Poppins', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 0.5px;
            color: #eaf6ff !important;
            transition: all 0.3s ease;
        }

        .navbar-brand:hover {
            color: #ffffff !important;
            transform: scale(1.05);
        }

        .navbar-brand .brand-text {
            color: #eaf6ff;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
        }

        .nav-link {
            font-weight: 600;
            color: rgba(255,255,255,0.8) !important;
            transition: all 0.3s ease;
            margin: 0 5px;
            border-radius: 6px;
        }

        .nav-link:hover {
            color: var(--primary-blue) !important;
            background: rgba(30, 64, 175, 0.2);
            padding-left: 10px;
        }

        .nav-link.active {
            color: var(--primary-blue) !important;
            background: rgba(30, 64, 175, 0.3);
        }
/* ============================= */
/* SERVICE CARDS */
/* ============================= */
.service-card {
    border-radius: 18px;
    border: none;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
    overflow: hidden;
    position: relative;
}

.service-card:hover {
    transform: translateY(-15px);
    box-shadow: 0 25px 60px rgb(255, 255, 255);
}

.service-card .card-body {
    padding: 40px 30px;
}

.service-card i {
    transition: all 0.4s ease;
}

.service-card:hover i {
    transform: scale(1.25) rotate(8deg);
}
.service-icon {
    width: 250px;
    height: 250px;
    object-fit: contain;
    transition: transform 0.4s ease;
}

.service-card:hover .service-icon {
    transform: scale(1.35);
}
/* Colores coherentes con marca */
.service-card .fa-brush {
    color: var(--primary-blue);
}

.service-card .fa-water {
    color: var(--primary-green);
}

.service-card .fa-paint-roller {
    color: var(--accent-light);
}

/* Botones coherentes */
.btn-service {
    background: var(--primary-blue);
    border: none;
    font-weight: 600;
    padding: 12px 25px;
    border-radius: 8px;
    transition: 0.3s ease;
}

.btn-service:hover {
    background: var(--primary-green);
    transform: translateY(-3px);
}

/* CTA Cotización */
.cta-services {
    margin-top: 60px;
}

.cta-services .btn {
    background: linear-gradient(135deg, var(--primary-green), var(--primary-blue));
    border: none;
    font-weight: 700;
    padding: 15px 50px;
    border-radius: 10px;
    transition: all 0.3s ease;
}

.cta-services .btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px #ffffff;
}

</style>

     <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="/images/logo.webp" alt="Pintumex" height="36" class="me-2">
                <span class="brand-text">PINTUMEX</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="/productos">Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/servicios">Servicios</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tiendas">Tiendas</a></li>
                    <li class="nav-item"><a class="nav-link" href="/acerca-de">Acerca de</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/carrito">
                            <i class="fas fa-shopping-cart"></i> Carrito
                            <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">0</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
 <!-- HERO -->
<div class="services-hero text-center">
    <div class="container">
        <h1 class="mb-3">Nuestros Servicios</h1>
        <p class="lead mb-0">
            En Pintumex Puebla ofrecemos soluciones profesionales para proyectos de pintura,
            protección y diseño con asesoría especializada.
        </p>
    </div>
</div>
<!-- SERVICIOS -->
<section class="container py-5">
    <div class="row g-4 mt-3">

        <!-- Servicio 1 -->
        <div class="col-md-4">
            <div class="card h-100 shadow service-card">
                <div class="card-body text-center">
                   <img src="/images/pintar.webp" 
                        alt="Servicio de Pintado"
                        class="service-icon mb-4">
                    <h5 class="fw-bold">Servicio de Pintado</h5>
                    <p class="text-muted">
                        Aplicación profesional de pintura en interiores y exteriores 
                        para hogares, oficinas y comercios.
                    </p>
                </div>
            </div>
        </div>

        <!-- Servicio 2 -->
        <div class="col-md-4">
            <div class="card h-100 shadow service-card">
                <div class="card-body text-center">
                    <img src="/images/impermeabilizar.webp" 
                        alt="Servicio de impermeabilización"
                        class="service-icon mb-4">
                    <h5 class="fw-bold">Impermeabilización</h5>
                    <p class="text-muted">
                        Sistemas especializados para proteger estructuras contra
                        humedad y filtraciones con alta durabilidad.
                    </p>
                </div>
            </div>
        </div>

        <!-- Servicio 3 -->
        <div class="col-md-4">
            <div class="card h-100 shadow service-card">
                <div class="card-body text-center">
                    <img src="/images/decorador.webp" 
                        alt="Decorador Virtual"
                        class="service-icon mb-4">
                        
                    <h5 class="fw-bold">Decorador Virtual</h5>
                    <p class="text-muted">
                        Visualiza combinaciones de colores y elige la mejor opción
                        antes de iniciar tu proyecto.
                    </p>
                    <a href="https://pintumex.com.mx/decorador/" 
                       target="_blank" 
                       rel="noopener"
                       class="btn btn-service mt-3">
                        Probar Decorador Virtual
                        <i class="fa-solid fa-arrow-up-right-from-square ms-2"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>

    <!-- CTA -->
    <div class="row cta-services">
        <div class="col-12 text-center">
            <a href="/contacto" class="btn btn-lg shadow">
                Solicitar Cotización
            </a>
        </div>
    </div>
</section>


