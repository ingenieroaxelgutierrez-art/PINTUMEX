            .section-title {
                font-size: 1.8rem;
            }

            .product-grid {
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
                gap: 20px;
            }

            .cta-title {
                font-size: 1.8rem;
            }
        }
    </style>
