<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/webp" href="/images/logo.webp">
    <link rel="apple-touch-icon" href="/images/logo.webp">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        :root {
            --primary-red: #1e40af;
            --dark-red: #16a34a;
            --primary-blue: #1976d2;
            --accent-gold: #ffa000;
            --light-bg: #f5f5f5;
            --dark-text: #212121;
        }

        .about-hero {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }

        .about-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120"><path d="M0,50 Q300,100 600,50 T1200,50 L1200,120 L0,120 Z" fill="rgba(255,255,255,0.1)"/></svg>');
            background-repeat: repeat-x;
            opacity: 0.5;
        }

        .about-hero h1 {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            position: relative;
            z-index: 1;
        }

        .about-hero p {
            font-size: 1.3rem;
            font-weight: 300;
            position: relative;
            z-index: 1;
        }

        .section-title {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--dark-text);
            margin-bottom: 50px;
            text-align: center;
            position: relative;
            padding-bottom: 25px;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: #1e40af;
            border-radius: 2px;
        }

        .history-image {
            border-radius: 12px;
            box-shadow: 0 10px 35px rgba(0,0,0,0.15);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .history-image:hover {
            transform: scale(1.02);
            box-shadow: 0 15px 45px rgba(30, 64, 175, 0.2);
        }

        .history-content h2 {
            font-size: 2rem;
            font-weight: 800;
            color: var(--dark-text);
            margin-bottom: 25px;
        }

        .history-content p {
            font-size: 1.05rem;
            color: #555;
            line-height: 1.8;
            margin-bottom: 20px;
        }

        .value-card {
            text-align: center;
            padding: 40px 30px;
            background: white;
            border-radius: 12px;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            border-top: 4px solid transparent;
            height: 100%;
        }

        .value-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(30, 64, 175, 0.15);
            border-top-color: #1e40af;
        }

        .value-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 25px;
            background: linear-gradient(135deg, #1e40af, #16a34a);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            transition: all 0.3s ease;
        }

        .value-card:hover .value-icon {
            transform: scale(1.15) rotate(-10deg);
        }

        .value-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--dark-text);
            margin-bottom: 15px;
        }

        .value-text {
            color: #666;
            font-size: 1rem;
            line-height: 1.6;
        }

        .team-gallery-wrapper {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 15px 50px rgba(0,0,0,0.18);
        }

        .team-carousel .carousel-item img {
            width: 100%;
            height: 520px;
            object-fit: cover;
            object-position: center;
        }

        .team-carousel .carousel-caption {
            background: linear-gradient(0deg, rgba(0,0,0,0.65) 0%, transparent 100%);
            bottom: 0;
            left: 0;
            right: 0;
            padding: 30px 40px 25px;
            text-align: left;
            border-radius: 0;
        }

        .team-carousel .carousel-caption h5 {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .team-carousel .carousel-caption p {
            font-size: 0.95rem;
            opacity: 0.88;
            margin: 0;
        }

        .team-carousel .carousel-control-prev,
        .team-carousel .carousel-control-next {
            width: 52px;
            height: 52px;
            background: rgba(30,64,175,0.75);
            border-radius: 50%;
            top: 50%;
            transform: translateY(-50%);
            margin: 0 12px;
        }

        .team-carousel .carousel-indicators [data-bs-target] {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background-color: rgba(255,255,255,0.7);
        }

        .team-carousel .carousel-indicators .active {
            background-color: #fff;
        }

        .team-intro-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            margin-bottom: 40px;
        }

        .team-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: white;
            border: 2px solid #1e40af;
            color: #1e40af;
            padding: 8px 22px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            box-shadow: 0 3px 10px rgba(30,64,175,0.1);
        }

        @media (max-width: 767px) {
            .team-carousel .carousel-item img {
                height: 280px;
            }
            .team-carousel .carousel-caption {
                padding: 16px 20px 14px;
            }
            .team-carousel .carousel-caption h5 {
                font-size: 1rem;
            }
        }

        .stats-section {
            background: linear-gradient(135deg, #1e40af, #1e3a8a);
            color: white;
            padding: 60px 0;
            margin: 60px 0;
        }

        .stat-item {
            text-align: center;
            padding: 30px;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .stat-label {
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .cta-section {
            background: linear-gradient(135deg, var(--light-bg) 0%, white 100%);
            padding: 60px 0;
            border-radius: 12px;
            text-align: center;
        }

        .cta-title {
            font-size: 2rem;
            font-weight: 800;
            color: var(--dark-text);
            margin-bottom: 20px;
        }

        .cta-text {
            font-size: 1.1rem;
            color: #666;
            margin-bottom: 40px;
        }

        .cta-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .cta-button {
            padding: 15px 40px;
            border-radius: 8px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .cta-primary {
            background: #1e40af;
            color: white;
            border: 2px solid #1e40af;
        }

        .cta-primary:hover {
            background: white;
            color: #1e40af;
        }

        .cta-secondary {
            background: white;
            color: #1e40af;
            border: 2px solid #1e40af;
        }

        .cta-secondary:hover {
            background: #1e40af;
            color: white;
        }

        @media (max-width: 767px) {
            .about-hero h1 {
                font-size: 2rem;
            }

            .about-hero p {
                font-size: 1rem;
            }

            .about-hero {
                padding: 50px 0;
            }

            .section-title {
                font-size: 1.8rem;
            }

            .stat-number {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <% 
        const primaryStore = (typeof stores !== 'undefined' && stores[0]) ? stores[0] : null;
        const secondaryStore = (typeof stores !== 'undefined' && stores[1]) ? stores[1] : null;
        const primaryWhatsapp = primaryStore ? (primaryStore.whatsapp || primaryStore.phone) : '522222941010';
    %>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="/images/logo.webp" alt="Pintumex" height="36" class="me-2">
                <span class="brand-text">PINTUMEX</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="/productos">Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/servicios">Servicios</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tiendas">Tiendas</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/acerca-de">Acerca de</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/carrito">
                            <i class="fas fa-shopping-cart"></i> Carrito
                            <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">0</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="about-hero">
        <div class="container position-relative" style="z-index: 2;">
            <h1><i class="fas fa-building me-3"></i>Acerca de Pintumex</h1>
            <p class="mb-0">Tu socio confiable en materiales de pintura desde 2010</p>
        </div>
    </section>

    <!-- History Section -->
    <section class="py-5">
        <div class="container">
            <div class="row align-items-center g-5 mb-5">
                <div class="col-lg-6">
                    <img src="/images/LEMA.webp" 
                         alt="Tienda Pintumex" class="img-fluid history-image">
                </div>
                <div class="col-lg-6">
                    <div class="history-content">
                        <h2><i class="fas fa-history me-2" style="color: var(--primary-red);"></i>Nuestra Historia</h2>
                        <p>
                            Pintumex fue fundada en 2010 con una visión clara: proporcionar materiales de pintura de alta calidad y un servicio excepcional a profesionales adinerados y personas que buscaban resultados de excelencia en sus proyectos.
                        </p>
                        <p>
                            Durante más de una década, hemos construido una reputación sólida basada en <strong>calidad, confianza y compromiso</strong> con nuestros clientes. Nuestro crecimiento ha sido constante, permitiéndonos expandir a dos ubicaciones estratégicas en Puebla para servir mejor a nuestra comunidad.
                        </p>
                        <p>
                            Hoy, Pintumex es sinónimo de productos originales, asesoría técnica profesional y soluciones personalizadas para todos tus proyectos de pintura.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="stat-item">
                        <div class="stat-number">
                            <i class="fas fa-calendar"></i>13+
                        </div>
                        <div class="stat-label">Años de Experiencia</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <div class="stat-number">
                            <i class="fas fa-users"></i>5000+
                        </div>
                        <div class="stat-label">Clientes Satisfechos</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <div class="stat-number">
                            <i class="fas fa-store"></i>2
                        </div>
                        <div class="stat-label">Sucursales</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <div class="stat-number">
                            <i class="fas fa-cube"></i>100+
                        </div>
                        <div class="stat-label">Productos Disponibles</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="py-5">
        <div class="container">
            <h2 class="section-title">Nuestros Valores</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="value-card">
                        <div class="value-icon">
                            <i class="fas fa-star"></i>
                        </div>
                        <h3 class="value-title">Calidad</h3>
                        <p class="value-text">
                            Ofrecemos solo productos originales de marcas reconocidas internacionalmente. Cada artículo es verificado para garantizar excelencia.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="value-card">
                        <div class="value-icon">
                            <i class="fas fa-handshake"></i>
                        </div>
                        <h3 class="value-title">Confianza</h3>
                        <p class="value-text">
                            Nuestros clientes son el corazón de nuestro negocio. Su satisfacción, confianza y fidelidad son lo más importante para nosotros.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="value-card">
                        <div class="value-icon">
                            <i class="fas fa-lightbulb"></i>
                        </div>
                        <h3 class="value-title">Innovación</h3>
                        <p class="value-text">
                            Nos mantenemos actualizados con las últimas tendencias y tecnologías en materiales de pintura para ofrecer las mejores soluciones.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="py-5" style="background: var(--light-bg);">
        <div class="container">
            <h2 class="section-title">Nuestro Equipo</h2>

            <!-- Badges de especialidad -->
            <div class="team-intro-badges">
                <span class="team-badge"><i class="fas fa-certificate"></i> Especialistas Certificados</span>
                <span class="team-badge"><i class="fas fa-paint-roller"></i> Asesores Técnicos</span>
                <span class="team-badge"><i class="fas fa-headset"></i> Atención Personalizada</span>
                <span class="team-badge"><i class="fas fa-store"></i> 2 Sucursales en Puebla</span>
            </div>

            <!-- Galería carousel -->
            <div class="team-gallery-wrapper">
                <div id="teamCarousel" class="carousel slide team-carousel" data-bs-ride="carousel" data-bs-interval="4000">

                    <div class="carousel-indicators">
                        <button type="button" data-bs-target="#teamCarousel" data-bs-slide-to="0" class="active"></button>
                        <button type="button" data-bs-target="#teamCarousel" data-bs-slide-to="1"></button>
                        <button type="button" data-bs-target="#teamCarousel" data-bs-slide-to="2"></button>
                        <button type="button" data-bs-target="#teamCarousel" data-bs-slide-to="3"></button>
                        <button type="button" data-bs-target="#teamCarousel" data-bs-slide-to="4"></button>
                    </div>

                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <img src="/images/EQUIPO.webp" alt="Equipo Pintumex">
                            <div class="carousel-caption">
                                <h5><i class="fas fa-users me-2"></i>Nuestro Equipo</h5>
                                <p>Un equipo comprometido con la calidad y la atención al cliente.</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="/images/EQUIPO2.webp" alt="Equipo Pintumex">
                            <div class="carousel-caption">
                                <h5><i class="fas fa-award me-2"></i>Especialistas en Pintura</h5>
                                <p>Más de 13 años formando profesionales en el ramo.</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="/images/TIENDA.webp" alt="Sucursal Pintumex">
                            <div class="carousel-caption">
                                <h5><i class="fas fa-store me-2"></i>Sucursal Cuautlancingo</h5>
                                <p>Amplio catálogo y asesoría técnica en piso de venta.</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="/images/TIENDA2.webp" alt="Sucursal Pintumex">
                            <div class="carousel-caption">
                                <h5><i class="fas fa-map-marker-alt me-2"></i>Sucursal San Pedro Cholula</h5>
                                <p>Tu segunda opción para productos de la más alta calidad.</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="/images/TIENDA3.webp" alt="Tienda Pintumex">
                            <div class="carousel-caption">
                                <h5><i class="fas fa-paint-brush me-2"></i>Listos para Asesorarte</h5>
                                <p>Visítanos y encuentra la solución perfecta para tu proyecto.</p>
                            </div>
                        </div>
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#teamCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#teamCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>
            </div>

            <div style="background: white; padding: 35px 40px; border-radius: 12px; text-align: center; box-shadow: 0 5px 20px rgba(0,0,0,0.08); margin-top: 30px;">
                <p style="color: #555; font-size: 1.05rem; line-height: 1.8; margin-bottom: 20px;">
                    Contamos con un equipo de <strong>especialistas certificados</strong> en aplicación y asesoría de pinturas, listos para guiarte desde la elección del producto hasta el resultado final. Tu satisfacción es nuestra prioridad.
                </p>
                <a href="/contacto" class="btn" style="background: #1e40af; color: white; padding: 12px 30px; border-radius: 6px; text-decoration: none; font-weight: 700;">
                    <i class="fas fa-envelope me-2"></i>Contáctanos
                </a>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-5">
        <div class="container">
            <div class="cta-section">
                <h2 class="cta-title">
                    <i class="fas fa-rocket me-2" style="color: var(--primary-red);"></i>¿Listo para Comenzar?
                </h2>
                <p class="cta-text">
                    Visita una de nuestras tiendas o compra en línea. Estamos aquí para apoyarte en cada paso.
                </p>
                <div class="cta-buttons">
                    <a href="/productos" class="cta-button cta-primary">
                        <i class="fas fa-shopping-bag me-2"></i>Ver Catálogo
                    </a>
                    <a href="/tiendas" class="cta-button cta-secondary">
                        <i class="fas fa-map-marker-alt me-2"></i>Nuestras Tiendas
                    </a>
                    <a href="https://wa.me/<%= primaryWhatsapp.replace(/[^0-9]/g, '') %>?text=Hola%20Pintumex,%20tengo%20una%20consulta" target="_blank" class="cta-button cta-secondary">
                        <i class="fab fa-whatsapp me-2"></i>Contactar
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container py-5">
            <div class="row mb-4 justify-content-between">
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-paint-brush me-2"></i>Pintumex</h5>
                    <p>Pinturas Mexicanas de Puebla S.A. de C.V.<br>Tu proveedor de confianza en pinturas y recubrimientos de la más alta calidad desde 2010.</p>
                </div>
                <div class="col-md-3 col-lg-2 mb-4">
                    <h5>Navegación</h5>
                    <ul class="list-unstyled mb-0">
                        <li><a href="/">Inicio</a></li>
                        <li><a href="/productos">Productos</a></li>
                        <li><a href="/servicios">Servicios</a></li>
                        <li><a href="/tiendas">Tiendas</a></li>
                        <li><a href="/acerca-de">Acerca de</a></li>
                        <li><a href="/contacto">Contacto</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Contacto</h5>
                    <p>
                        <% if (primaryStore) { %>
                            <i class="fas fa-phone me-2"></i><%= primaryStore.phone %><br>
                        <% } %>
                        <% if (secondaryStore) { %>
                            <i class="fas fa-phone me-2"></i><%= secondaryStore.phone %><br>
                        <% } %>
                        <% if (primaryStore) { %>
                            <i class="fas fa-envelope me-2"></i><%= primaryStore.email %><br>
                            <i class="fas fa-map-marker-alt me-2"></i><%= primaryStore.address %>
                        <% } %>
                    </p>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.15); margin-bottom: 1.5rem;">
            <div class="footer-bottom">
                <p class="footer-legal">
                    <span class="footer-legal-line">&copy; 2026 Pintumex Puebla | Diseñado por: Axel Gutiérrez</span>
                    <span class="footer-legal-line"><span class="footer-legal-links"><a href="/terminos">Términos y Condiciones</a> <span style="opacity:0.5">|</span> <a href="/privacidad">Política de Privacidad</a></span></span>
                </p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>


